# Configuration Backend MDMC Reporting IA
# Copiez ce fichier vers .env et remplissez vos vraies valeurs

# Clé API Gemini 2.5 Pro (OBLIGATOIRE)
# Obtenez votre clé sur https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Port du serveur backend
PORT=3001

# Environnement de développement
NODE_ENV=development

# Future: Google Ads API (Phase 2)
# GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# GOOGLE_ADS_CLIENT_ID=your_client_id
# GOOGLE_ADS_CLIENT_SECRET=your_client_secret
