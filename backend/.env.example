# Configuration Backend MDMC Reporting IA
# Copiez ce fichier vers .env et remplissez vos vraies valeurs

# Clé API Gemini 2.5 Pro (OBLIGATOIRE)
# Obtenez votre clé sur https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Port du serveur backend
PORT=3001

# Environnement
NODE_ENV=development

# Google Ads API (PRODUCTION)
GOOGLE_ADS_DEVELOPER_TOKEN=CxDKMTI2CrPhkaNgHtwkoA
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_for_testing

# Base de données (pour future implémentation)
# DATABASE_URL=postgresql://user:password@host:port/database
# REDIS_URL=redis://host:port

# Sécurité (pour future implémentation)
# JWT_SECRET=your_jwt_secret_here

# CORS (production)
# CORS_ORIGIN=https://yourdomain.com
