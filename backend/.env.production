# Configuration Backend MDMC Reporting - PRODUCTION
# Variables d'environnement pour Railway

# Port (Railway définit automatiquement)
PORT=3001

# Environnement
NODE_ENV=production

# Clé API Gemini 2.5 Pro (à configurer dans Railway)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Ads API - Configuration Production
GOOGLE_ADS_DEVELOPER_TOKEN=CxDKMTI2CrPhkaNgHtwkoA
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-production-domain.com/auth/callback

# CORS pour la production
CORS_ORIGIN=https://your-production-domain.com

# Instructions de configuration:
# 1. Dans Railway, ajouter ces variables dans l'onglet Variables
# 2. Remplacer your_gemini_api_key_here par votre vraie clé Gemini
# 3. Remplacer your_google_client_id_here par votre Client ID Google Cloud
# 4. Remplacer your_google_client_secret_here par votre Client Secret Google Cloud
# 5. Remplacer your-production-domain.com par votre domaine Railway
